# ── Database ──────────────────────────────────────────────────────────────────
# MySQL / MariaDB connection string
DATABASE_URL=mysql+aiomysql://aistra:aistra123@localhost:3306/aistra_stream

# ── Security ──────────────────────────────────────────────────────────────────
# OBRIGATÓRIO: gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
# O serviço NÃO inicia se SECRET_KEY não estiver definido ou tiver < 32 chars
SECRET_KEY=GERE_UMA_CHAVE_SEGURA_AQUI_MINIMO_32_CHARS

# Minutos até o token expirar (padrão: 24h)
TOKEN_EXPIRE_MINUTES=1440

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origens permitidas (vírgula separadas). Deixe vazio para só localhost.
# Exemplo: ALLOWED_ORIGINS=https://meupanel.com,https://www.meupanel.com
ALLOWED_ORIGINS=

# ── Rate Limiting (login) ─────────────────────────────────────────────────────
# Máximo de tentativas de login por IP dentro da janela de tempo
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=60

# ── Streaming Tools ───────────────────────────────────────────────────────────
FFMPEG=/usr/bin/ffmpeg
N_M3U8DL=/usr/local/bin/n_m3u8dl
MP4DECRYPT=/usr/local/bin/mp4decrypt
YTDLP=/usr/local/bin/yt-dlp
YTDLP_COOKIES=/opt/youtube_cookies.txt

# ── Temp directories (criados automaticamente) ───────────────────────────────
HLS_BASE=/tmp/aistra_stream_hls
PIPE_BASE=/tmp/aistra_stream_pipes
TMP_BASE=/tmp/aistra_stream_tmp
THUMBNAILS_BASE=/tmp/aistra_thumbnails

# ── Persistent directories ────────────────────────────────────────────────────
RECORDINGS_BASE=/opt/aistra-stream/recordings
LOGOS_BASE=/opt/aistra-stream/logos

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001

# ── Telegram (opcional — alertas de ban/crash/restart) ───────────────────────
# Crie um bot em @BotFather e adicione ao grupo/canal
# TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff
# TELEGRAM_CHAT_ID=-100123456789

# ── Dev / Debug (NÃO use em produção) ────────────────────────────────────────
# AISTRA_SHOW_DOCS=1        # Habilita /docs e /openapi.json
# AISTRA_INSECURE_KEY=1     # Permite rodar sem SECRET_KEY (dev only)
